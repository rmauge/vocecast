// Prisma schema for Vocecast
// Better Auth tables: User, Session, Account, Verification
// Domain models: Organization, Client, Template, VoiceClone, VoiceSample, ScheduledReminder, TransactionOutbox, ProviderApiKey

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  POWER_USER
  USER
}

enum CloneProvider {
  ELEVENLABS
}

enum ReminderOffset {
  DAY_BEFORE_MORNING
  DAY_BEFORE_AFTERNOON
  DAY_BEFORE_EVENING
}

enum CallStatus {
  NOT_STARTED
  STARTED
  COMPLETED
  BUSY
  NO_ANSWER
  CANCELLED
  FAILED
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Better Auth tables ─────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  // Domain fields
  role  UserRole @default(USER)
  orgId String?
  org   Organization? @relation(fields: [orgId], references: [id])

  // Better Auth relations
  sessions Session[]
  accounts Account[]

  // Domain relations
  templates    Template[]
  voiceClones  VoiceClone[]
  voiceSamples VoiceSample[]
  clients      Client[]

  @@unique([email])
  @@index([orgId])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

// ─── Domain models ──────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String   @db.VarChar(255)
  email     String?  @unique
  phone     String?

  users        User[]
  clients      Client[]
  templates    Template[]
  voiceClones  VoiceClone[]
  voiceSamples VoiceSample[]
  apiKeys      ProviderApiKey[]
}

model Client {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  firstName     String
  lastName      String
  preferredName String?
  email         String
  phoneNumber   String

  orgId    String
  org      Organization @relation(fields: [orgId], references: [id])
  authorId String
  author   User         @relation(fields: [authorId], references: [id])

  scheduledReminders ScheduledReminder[]

  @@unique([email, orgId])
  @@index([orgId])
}

model Template {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  content   String

  orgId    String
  org      Organization @relation(fields: [orgId], references: [id])
  authorId String
  author   User         @relation(fields: [authorId], references: [id])

  scheduledReminders ScheduledReminder[]

  @@index([orgId])
}

model VoiceClone {
  id            String        @id @default(cuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  name          String
  description   String?
  cloneProvider CloneProvider
  providerId    String        @unique

  orgId    String
  org      Organization @relation(fields: [orgId], references: [id])
  authorId String
  author   User         @relation(fields: [authorId], references: [id])

  scheduledReminders ScheduledReminder[]

  @@index([orgId])
}

model VoiceSample {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  filename    String
  name        String
  description String?
  storageKey  String?

  orgId    String
  org      Organization @relation(fields: [orgId], references: [id])
  authorId String
  author   User         @relation(fields: [authorId], references: [id])

  @@index([orgId])
}

model ScheduledReminder {
  id              String         @id @default(cuid())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  timeZone        String
  appointmentTime DateTime
  reminderOffset  ReminderOffset
  status          CallStatus     @default(NOT_STARTED)
  attempts        Int            @default(0)
  lastAttempt     DateTime?

  orgId      String
  userId     String
  clientId   String
  client     Client    @relation(fields: [clientId], references: [id])
  templateId String
  template   Template  @relation(fields: [templateId], references: [id])
  voiceId    String
  voice      VoiceClone @relation(fields: [voiceId], references: [id])

  @@index([orgId])
  @@index([status])
}

model TransactionOutbox {
  id        String            @id @default(cuid())
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  eventType String
  payload   Json
  status    TransactionStatus @default(PENDING)
  error     String?
  retries   Int               @default(0)

  @@index([status])
}

model ProviderApiKey {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  provider  String
  apiKey    String

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, provider])
}
